# Byte-compiled / cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
.eggs/
dist/
build/
*.manifest

# Virtual environments
.venv/
venv/
ENV/
env/

# Environment & secrets (never commit)
.env
.env.*
!.env.example
*.pem
cookies.txt

# Test / tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/

# Editors / OS
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
Desktop.ini

# Wordly runtime data (recreated on launch; large binaries)
/downloads/
/exports/
/temp/
/clips/

# Downloaded instrumentals (yt-dlp cache; recreated by the wizard)
/assets/music/*
!/assets/music/.gitkeep
